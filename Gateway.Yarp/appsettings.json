{
  "ReverseProxy": {
    "Routes": {
      "author_graphql": {
        "ClusterId": "authorCluster",
        "Match": {
          "Path": "/graphql/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "authorCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },
  "AllowedHosts": "*"
}
