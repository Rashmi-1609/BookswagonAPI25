{
  "ReverseProxy": {
    "Routes": {
      "author_graphql": {
        "ClusterId": "authorCluster",
        "Match": {
          "Path": "/graphql/{featured-author}"
        }
      },
      "product_graphql": {
        "ClusterId": "productCluster",
        "Match": {
          "Path": "/graphql/{product-review}"
        }
      }
    },
    "Clusters": {
      "authorCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5028/"
          }
        }
      },
      "productCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5183/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },
  "AllowedHosts": "*"
}
